# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Строка подключения MongoDB Atlas, бесплатный кластер M0 (обязательно)
# Пример: mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/mp2pstore
MONGODB_URI=

# Скрытая команда входа в режим администратора (по умолчанию /Admin7788)
ADMIN_SECRET=/Admin7788

# Telegram ID администраторов через запятую (необязательно)
ADMIN_IDS=

# Username для кнопки "ЛС" без символа @ (по умолчанию msgp2p)
CONTACT_USERNAME=msgp2p

# Название магазина (по умолчанию mP2Pstore)
STORE_NAME=mP2Pstore

# Сколько товаров показывать на одной странице каталога (по умолчанию 8)
PAGE_SIZE=8

# Необязательно: публичный URL для webhook вне Render (на Render подставляется сам)
PUBLIC_URL=

# Необязательно: секрет для webhook-пути (по умолчанию вычисляется из токена)
WEBHOOK_SECRET=
